<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    android:id="@+id/coordinator"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android">
   <com.google.android.material.appbar.AppBarLayout
       android:layout_width="match_parent"
       android:layout_height="wrap_content"
       android:background="@android:color/transparent"
       >
       <androidx.appcompat.widget.Toolbar
           android:id="@+id/toolbar"
           android:layout_width="match_parent"
           android:background="#ffffff"
           app:title="Toolbar"
           android:elevation="2dp"
           android:theme="@style/ThemeOverlay.AppCompat.Light"
           android:layout_height="?attr/actionBarSize"/>
   </com.google.android.material.appbar.AppBarLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"

        >
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            xmlns:tools="http://schemas.android.com/tools"
            android:layout_height="match_parent"
            android:layout_width="match_parent"
            xmlns:android="http://schemas.android.com/apk/res/android">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="8dp">


                <TextView
                    android:id="@+id/from"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/edit_corner2"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="start|center"
                    android:padding="10dp"
                    android:paddingStart="15dp"
                    android:text="null"
                    android:textSize="15sp"
                    android:visibility="invisible"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/from_code"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/view"
                    android:layout_width="0dp"
                    android:layout_height="0.5dp"
                    android:layout_marginTop="24dp"
                    android:background="#788365"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/from_code"
                    app:layout_constraintTop_toBottomOf="@+id/from" />

                <TextView
                    android:id="@+id/to"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/edit_corner2"
                    android:gravity="center|start"
                    android:padding="10dp"
                    android:paddingStart="15dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="null"
                    android:textSize="15sp"
                    android:visibility="invisible"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/from"
                    app:layout_constraintTop_toTopOf="@+id/view" />


                <TextView
                    android:id="@+id/from_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/edit_corner"
                    android:ems="4"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="null"
                    android:clickable="true"
                    android:focusable="true"
                    android:textColor="#000"
                    android:textSize="18sp"
                    android:visibility="invisible"
                    app:layout_constraintBottom_toBottomOf="@+id/from"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/from" />


                <TextView
                    android:id="@+id/to_code"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/edit_corner"
                    android:ems="4"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="null"
                    android:textColor="#000"
                    android:textSize="18sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="invisible"
                    app:layout_constraintBottom_toBottomOf="@+id/to"
                    app:layout_constraintEnd_toEndOf="@+id/from_code"
                    app:layout_constraintStart_toStartOf="@+id/from_code"
                    app:layout_constraintTop_toTopOf="@+id/to" />

                <ImageView
                    android:id="@+id/flip"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="32dp"
                    android:layout_marginBottom="8dp"
                    android:background="#fff"
                    android:clickable="true"
                    android:focusable="true"
                    android:foregroundGravity="top"
                    android:src="@drawable/ic_swap_vert_black_24dp"
                    app:layout_constraintBottom_toTopOf="@+id/to"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/from"
                    app:layout_constraintVertical_bias="0.375" />

                <TextView
                    android:id="@+id/source_station"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/edit_corner"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="start|center"
                    android:onClick="click"
                    android:visibility="visible"
                    android:padding="10dp"
                    android:paddingStart="15dp"
                    android:text="Source Station"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/destination_station"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/edit_corner"
                    android:gravity="center|start"
                    android:visibility="visible"
                    android:padding="10dp"
                    android:paddingStart="15dp"
                    android:text="Destination Station"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/source_station"
                    app:layout_constraintTop_toTopOf="@+id/view" />


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginTop="8dp"
                    android:padding="10dp"
                    android:paddingStart="15dp"
                    android:text="Departure Date"
                    android:textSize="15dp"
                    app:layout_constraintStart_toStartOf="@+id/destination_station"
                    app:layout_constraintTop_toBottomOf="@+id/to_code" />


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/date_picker"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="48dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/edit_corner"
                    android:clickable="true"
                    android:elevation="0dp"
                    android:focusable="true"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/destination_station">

                    <ImageView
                        android:id="@+id/calender"
                        android:layout_width="35dp"
                        android:layout_height="0dp"
                        android:layout_marginEnd="24dp"
                        android:src="@drawable/agenda"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:ems="1"
                        android:gravity="center"
                        android:text="03"
                        android:textSize="40sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/month"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="April"
                        android:textSize="14sp"
                        app:layout_constraintBottom_toTopOf="@+id/day_name"
                        app:layout_constraintStart_toEndOf="@+id/date"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/day_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Saturday"
                        android:textSize="11sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="@+id/month"
                        app:layout_constraintTop_toBottomOf="@+id/month" />

                </androidx.constraintlayout.widget.ConstraintLayout>


                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="#788365"
                    android:elevation="5dp"
                    android:text="Search Train"
                    android:textAllCaps="false"
                    android:textColor="#fff"
                    android:textSize="15sp"
                    app:cornerRadius="8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.54"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/date_picker"
                    app:rippleColor="#fff" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
    <include layout="@layout/search_bottom_sheet"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>